[custom]
; 基础设置
enable_rule_generator = true
overwrite_original_rules = true

; 极简策略组 (测试正则是否能抓到节点)
custom_proxy_group = 代理模式`select`.*
custom_proxy_group = 自动选择`url-test`.*`http://www.gstatic.com/generate_204`300,,100

; 极简规则 (先不要用 Rule-Provider，测试规则引擎是否生效)
custom_rule = DOMAIN,api.ipify.org,代理模式
custom_rule = MATCH,代理模式
